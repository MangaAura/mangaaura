{
  // ───── i18n-ally: Detección de claves faltantes en traducciones ─────
  "i18n-ally.localesPaths": "src/i18n/locales",
  "i18n-ally.keystyle": "nested",
  "i18n-ally.sourceLanguage": "en",
  "i18n-ally.displayLanguage": "en",
  "i18n-ally.enabledParsers": ["json"],
  "i18n-ally.extract.autoDetect": true,
  "i18n-ally.annotations": true,
  "i18n-ally.annotationInPlace": true,
  "i18n-ally.review.enabled": true,
  "i18n-ally.review.gutters": true,
  "i18n-ally.refactor.templates": [
    "t('{key}')",
    "{t('{key}')}"
  ],
  "i18n-ally.translate.deeplApiKey": "",

  // ───── General ─────
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": true
  }
}
