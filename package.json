    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "next-pwa": "^5.6.0",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "tsc-files": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
