{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "agentmemory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@agentmemory/mcp"
      ],
      "enabled": true
    }
  }
}
