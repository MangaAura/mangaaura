generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  username         String    @unique
  displayName      String?
  avatarUrl        String?
  passwordHash     String?
  emailVerified    DateTime?
  xpPoints         Int       @default(0)
  inkcoinsBalance  Int       @default(0)
  level            Int       @default(1)
  readingStreak    Int       @default(0)
  lastReadAt       DateTime?
  streakFreezes    Int       @default(2)
  lastStreakMilestone Int    @default(0)
  role String @default("USER")
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  twoFactorBackupCodes String?
  emailPreferences String @default("{}")
  stripeCustomerId    String?   @unique
  subscriptionId      String?
  subscriptionStatus  String?
  subscriptionTier    String?
  subscriptionEndsAt  DateTime?
  pushSubscription    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts                  Account[]
  sessions                  Session[]
  achievements              UserAchievement[]
  mangaList                 UserManga[]
  library                   UserLibrary[]
  readingProgress           ReadingProgress[]
  createdMangas             MangaSeries[]              @relation("CreatedMangas")
  corrections               ChapterCorrection[]
  readingSessions           ReadingSession[]
  transactions              Transaction[]
  sponsorshipBids           SponsorshipBid[]
  notifications             Notification[]
  tipsGiven                 Tip[]                      @relation("TipsGiven")
  tipsReceived              Tip[]                      @relation("TipsReceived")
  crowdfundingContributions CrowdfundingContribution[]
  clanMemberships           ClanMembership[]
  comments                  Comment[]
  commentLikes              CommentLike[]
  mentions                  CommentMention[]           @relation("Mentions")
  activities                UserActivity[]
  ledClan                   Clan?                      @relation("ClanLeader")
  pushSubscriptions         PushSubscription[]
  quests                    UserQuest[]

  // Security & Social
  reportsMade      UserReport[]       @relation("ReportsMade")
  reportsReceived  UserReport[]       @relation("ReportsReceived")
  assignedReports  UserReport[]       @relation("AssignedReports")
  securityAudits   SecurityAuditLog[] @relation("SecurityAudits")
  refreshTokens    RefreshToken[]
  following        Follow[]           @relation("Following")
  followers        Follow[]           @relation("UserFollowers")
  activitiesFeed   Activity[]         @relation("Activities")
  conversations1   Conversation[]     @relation("Participant1")
  forumThreads     ForumThread[]
  forumPosts       ForumPost[]
  contactMessages  ContactMessage[]
  conversations2   Conversation[]     @relation("Participant2")
  directMessages   DirectMessage[]
  collections        Collection[]          @relation("Collections")
  collectionLikes    CollectionLike[]
  collectionCollaborators CollectionCollaborator[]
  webhookEndpoints   WebhookEndpoint[]
  bookmarks          Bookmark[]
  newsArticles       NewsArticle[]
  reposts          Repost[]           @relation("Reposts")
  eventSubmissions EventSubmission[]
  eventVotes       EventVote[]
  createdEvents    Event[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([xpPoints])
}

model MangaSeries {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  coverUrl    String?
  authorId    String
  authorName  String
  status      String   @default("ONGOING")
  tags        String
  totalViews  Int      @default(0)
  rating      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author          User              @relation("CreatedMangas", fields: [authorId], references: [id], onDelete: Cascade)
  chapters        Chapter[]
  libraryEntries  UserLibrary[]
  userMangas      UserManga[]
  readingProgress ReadingProgress[]
  collectionItems CollectionItem[]
  bookmarks       Bookmark[]

  @@index([slug])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@index([totalViews])
  @@index([updatedAt])
}

model Chapter {
  id                  String   @id @default(uuid())
  mangaId             String
  chapterNumber       Int
  title               String?
  totalPages          Int      @default(0)
  pageUrls            String
  crowdfundingGoal    Int?
  crowdfundingCurrent Int      @default(0)
  isCrowdfunded       Boolean  @default(false)
  viewCount           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  manga                     MangaSeries                @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  comments                  Comment[]
  readingProgress           ReadingProgress[]
  tips                      Tip[]
  crowdfundingContributions CrowdfundingContribution[]
  sponsorshipBids           SponsorshipBid[]
  readingSessions           ReadingSession[]
  bookmarks                 Bookmark[]
  corrections               ChapterCorrection[]

  @@unique([mangaId, chapterNumber])
  @@index([mangaId])
  @@index([createdAt])
}

model UserLibrary {
  id             String   @id @default(uuid())
  userId         String
  mangaId        String
  status         String   @default("READING")
  currentChapter Int      @default(0)
  rating         Float?
  addedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
  @@index([mangaId])
}

model ReadingProgress {
  id              String    @id @default(uuid())
  userId          String
  mangaId         String
  chapterId       String
  currentPage     Int       @default(0)
  percentage      Float     @default(0)
  completed       Boolean   @default(false)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())
  durationSeconds Int       @default(0)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  manga   MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId, chapterId])
  @@index([userId])
  @@index([userId, mangaId])
  @@index([chapterId])
  @@index([completed])
}

model Comment {
  id           String   @id @default(uuid())
  chapterId    String
  userId       String
  content      String
  parentId     String?
  likesCount   Int      @default(0)
  isDeleted    Boolean  @default(false)
  isHidden     Boolean  @default(false)
  hiddenReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chapter  Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?         @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[]        @relation("CommentReplies")
  likes    CommentLike[]
  mentions CommentMention[]

  @@index([chapterId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommentMention {
  id              String   @id @default(uuid())
  commentId       String
  mentionedUserId String
  createdAt       DateTime @default(now())
  isRead          Boolean  @default(false)

  comment       Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User    @relation("Mentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([mentionedUserId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  linkUrl   String?
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  type        String
  referenceId String?
  description String?
  timestamp   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}

model Tip {
  id         String   @id @default(uuid())
  chapterId  String
  fromUserId String
  toUserId   String
  amount     Int
  message    String?
  createdAt  DateTime @default(now())

  chapter  Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  fromUser User    @relation("TipsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("TipsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([toUserId])
  @@index([fromUserId])
  @@index([createdAt])
}

model CrowdfundingContribution {
  id          String   @id @default(uuid())
  chapterId   String
  userId      String
  amount      Int
  isAnonymous Boolean  @default(false)
  message     String?
  createdAt   DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chapterId, userId])
  @@index([chapterId])
  @@index([userId])
}

model Clan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  emblemUrl     String?
  totalScore    Int      @default(0)
  monthlyScore  Int      @default(0)
  currentSeason Int      @default(1)
  leaderId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leader  User?            @relation("ClanLeader", fields: [leaderId], references: [id])
  members ClanMembership[]

  @@index([totalScore])
  @@index([monthlyScore])
}

model ClanMembership {
  id               String   @id @default(uuid())
  clanId           String
  userId           String
  role             String   @default("MEMBER")
  joinedAt         DateTime @default(now())
  contributedScore Int      @default(0)

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model UserManga {
  id         String   @id @default(uuid())
  userId     String
  mangaId    String
  status     String   @default("PLANNED")
  progress   Int      @default(0)
  rating     Float?
  isFavorite Boolean  @default(false)
  addedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
  @@index([status])
}

model ChapterCorrection {
  id             String    @id @default(uuid())
  chapterId      String
  userId         String
  correctionText String
  status         String    @default("PENDING")
  rewardAmount   Int       @default(0)
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([userId])
  @@index([status])
}

model ReadingSession {
  id              String    @id @default(uuid())
  userId          String
  chapterId       String
  durationSeconds Int       @default(0)
  startedAt       DateTime  @default(now())
  endedAt         DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chapterId])
}

model SponsorshipBid {
  id          String    @id @default(uuid())
  chapterId   String
  userId      String
  bidAmount   Int
  status      String    @default("ACTIVE")
  isWinning   Boolean   @default(false)
  message     String?
  sponsorName String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([chapterId])
  @@index([userId])
}

model UserActivity {
  id           String   @id @default(uuid())
  userId       String
  activityType String
  referenceId  String?
  metadata     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
}

model AchievementDefinition {
  id          String   @id @default(uuid())
  badgeId     String   @unique
  xpReward    Int
  name        String
  description String
  iconUrl     String?
  condition   String
  category    String   @default("general")
  difficulty  String   @default("EASY")
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserQuest {
  id           String    @id @default(uuid())
  userId       String
  questId      String
  progress     Int       @default(0)
  target       Int
  completed    Boolean   @default(false)
  completedAt  DateTime?
  claimed      Boolean   @default(false)
  claimedAt    DateTime?
  periodStart  DateTime
  periodEnd    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, periodStart])
  @@index([userId])
  @@index([userId, completed])
  @@index([periodEnd])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Analytics models (for future use with proper analytics system)
model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model NewsArticle {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  titleEn     String?
  excerptEn   String?
  contentEn   String?
  coverUrl    String?
  category    String    @default("platform")
  authorId    String
  isPublished Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  publishedAt DateTime?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([scheduledAt])
  @@index([category])
  @@index([createdAt])
}

model DailyStats {
  id        String   @id @default(uuid())
  date      DateTime @unique
  mangaId   String?
  views     Int      @default(0)
  reads     Int      @default(0)
  newUsers  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([date])
}

model HourlyStats {
  id        String   @id @default(uuid())
  hour      DateTime
  eventType String
  count     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([hour, eventType])
  @@index([hour])
}

model ReaderRetention {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime
  isActive     Boolean  @default(false)
  chaptersRead Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ──────────────────────────────────────────────
// Genres
// ──────────────────────────────────────────────

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([name])
}

model RateLimit {
  id         String   @id @default(uuid())
  identifier String   @unique
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())

  @@index([resetAt])
}

// User Reporting System
model UserReport {
  id                String    @id @default(uuid())
  reporterId        String
  reportedUserId    String?
  reportedMangaId   String?
  reportedChapterId String?
  reportedCommentId String?
  reportType        String // HARASSMENT, SPAM, INAPPROPRIATE_CONTENT, COPYRIGHT_VIOLATION, etc.
  reason            String
  description       String?
  evidenceUrl       String?
  status            String    @default("PENDING") // PENDING, UNDER_REVIEW, RESOLVED, DISMISSED, ESCALATED
  priority          String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  assignedTo        String?
  resolution        String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reporter          User  @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser      User? @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  assignedModerator User? @relation("AssignedReports", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([reportedMangaId])
  @@index([reportedChapterId])
  @@index([reportedCommentId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
}

// Security Audit Logs
model SecurityAuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String // BAN_USER, DELETE_MANGA, PROMOTE_ADMIN, etc.
  targetId   String? // ID of the affected resource
  targetType String? // USER, MANGA, CHAPTER, COMMENT
  metadata   String? // JSON with additional details
  ipAddress  String?
  userAgent  String?
  severity   String   @default("INFO") // INFO, WARNING, ERROR, CRITICAL
  createdAt  DateTime @default(now())

  user User? @relation("SecurityAudits", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
}

// DMCA/Copyright Reports
model DMCATakedown {
  id                      String    @id @default(uuid())
  requesterName           String
  requesterEmail          String
  requesterAddress        String?
  infringingContentId     String?
  infringingContentType   String? // MANGA, CHAPTER
  originalWorkUrl         String?
  originalWorkDescription String?
  goodFaithStatement      Boolean
  signature               String
  status                  String    @default("PENDING") // PENDING, UNDER_REVIEW, REMOVED, REJECTED
  submittedAt             DateTime  @default(now())
  reviewedAt              DateTime?
  reviewedBy              String?
  resolutionNotes         String?

  @@index([status])
  @@index([submittedAt])
}

// Follow System
model Follow {
  id            String   @id @default(uuid())
  followerId    String
  followingId   String
  followingType String   @default("USER") // USER, MANGA
  createdAt     DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId, followingType])
  @@index([followerId])
  @@index([followingId, followingType])
}

// Activity Feed
model Activity {
  id           String   @id @default(uuid())
  userId       String
  activityType String // READ_CHAPTER, FOLLOW_USER, COMMENT, ACHIEVEMENT, etc.
  targetId     String?
  targetType   String?
  metadata     String? // JSON with details
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation("Activities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
  @@index([isPublic])
}

// Direct Messages
model Conversation {
  id             String   @id @default(uuid())
  participant1Id String
  participant2Id String
  lastMessageAt  DateTime @default(now())
  isBlocked      Boolean  @default(false)
  blockedBy      String?
  createdAt      DateTime @default(now())

  participant1 User            @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User            @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     DirectMessage[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model DirectMessage {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// Public Collections/Lists
model CollectionCollaborator {
  id           String     @id @default(uuid())
  collectionId String
  userId       String
  role         String     @default("EDITOR")
  addedAt      DateTime   @default(now())
  addedById    String?

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId])
  @@index([userId])
  @@index([collectionId])
}

model CollectionLike {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([collectionId, userId])
  @@index([userId])
}

model Collection {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  coverUrl    String?
  isPublic    Boolean  @default(true)
  likesCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                    @relation("Collections", fields: [userId], references: [id], onDelete: Cascade)
  items         CollectionItem[]
  likes         CollectionLike[]
  collaborators CollectionCollaborator[]

  @@index([userId])
  @@index([isPublic])
  @@index([likesCount])
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String
  mangaId      String
  addedAt      DateTime @default(now())

  collection Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  manga      MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([collectionId, mangaId])
  @@index([collectionId])
}

// Reposts/Shares
model Bookmark {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mangaId   String
  manga     MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter?    @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  page      Int         @default(0)
  note      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, mangaId, chapterId])
  @@index([userId])
  @@index([mangaId])
}

model WebhookEndpoint {
  id              String    @id @default(uuid())
  userId          String
  url             String
  secret          String
  events          String
  isActive        Boolean   @default(true)
  description     String?
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
}

model WebhookDelivery {
  id           String             @id @default(uuid())
  endpointId   String
  event        String
  payload      String
  status       String             @default("PENDING")
  statusCode   Int?
  responseBody String?
  durationMs   Int?
  attemptCount Int                @default(1)
  error        String?
  createdAt    DateTime           @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status])
  @@index([createdAt])
}

model Repost {
  id           String   @id @default(uuid())
  userId       String
  originalType String // MANGA, CHAPTER, COMMENT
  originalId   String
  comment      String?
  createdAt    DateTime @default(now())

  user User @relation("Reposts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, originalType, originalId])
  @@index([userId])
  @@index([originalId, originalType])
  @@index([createdAt])
}

// Creator Community Forum
model ForumCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads ForumThread[]

  @@index([slug])
  @@index([order])
}

model ForumThread {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  tags      String   @default("[]")
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  posts      ForumPost[]

  @@index([authorId])
  @@index([categoryId])
  @@index([slug])
  @@index([createdAt])
  @@index([isPinned])
}

model ForumPost {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([threadId])
  @@index([createdAt])
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String
  subject    String
  message    String
  category   String   @default("general")
  status     String   @default("PENDING")
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  adminNotes String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model Event {
  id           String            @id @default(uuid())
  title        String
  description  String
  type         String            @default("ART_CHALLENGE")
  basePrompt   String?
  prize        String
  startDate    DateTime
  endDate      DateTime
  status       String            @default("ACTIVE")
  participants Int               @default(0)
  imageUrl     String?
  color        String            @default("from-[var(--accent-blue)]/40 to-[var(--accent-purple)]/40")
  borderColor  String            @default("border-accent-blue/30")
  createdBy    String?
  creator      User?             @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  submissions  EventSubmission[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([type])
  @@index([endDate])
}

model EventSubmission {
  id         String      @id @default(uuid())
  eventId    String
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl   String
  prompt     String?
  votes      Int         @default(0)
  eventVotes EventVote[]
  createdAt  DateTime    @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([votes])
}

model EventVote {
  id           String          @id @default(uuid())
  submissionId String
  submission   EventSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@unique([submissionId, userId])
  @@index([submissionId])
  @@index([userId])
}

// Inbound Email Processing
model InboundEmail {
  id              String    @id @default(uuid())
  messageId       String    @unique
  fromEmail       String
  fromName        String?
  toEmail         String
  subject         String
  textBody        String
  htmlBody        String?
  intent          String    @default("unknown") // comment_reply, support, report, unsubscribe, spam, unknown
  confidence      Float?
  action          String    @default("pending") // replied, forwarded, processed, ignored, pending
  userId          String?   // identified user
  metadata        String?   // JSON with extracted entities (commentId, mangaSlug, etc.)
  internalNotes   String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([fromEmail])
  @@index([intent])
  @@index([action])
  @@index([createdAt])
  @@index([processedAt])
}

// CSP Violation Reports — received via report-uri directive
model CspReport {
  id                String   @id @default(uuid())
  blockedUri        String
  violatedDirective String
  documentUri       String
  effectiveDirective String?
  originalPolicy    String?
  scriptSample      String?
  sourceFile        String?
  lineNumber        Int?
  columnNumber      Int?
  disposition       String   @default("enforce")
  isExtensionNoise  Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([violatedDirective])
  @@index([isExtensionNoise])
  @@index([createdAt])
  @@index([disposition])
}
