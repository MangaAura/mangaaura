// PostgreSQL Schema for Production
// Copy this to schema.prisma and run: npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For connection pooling with PgBouncer (recommended for production)
  // directUrl = env("DIRECT_DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  emailVerified       DateTime?
  username            String    @unique
  displayName         String?
  avatarUrl           String?
  passwordHash        String?
  role                String    @default("USER")
  xpPoints            Int       @default(0)
  level               Int       @default(1)
  inkcoinsBalance     Int       @default(0)
  readingStreak       Int       @default(0)
  lastReadAt          DateTime?
  emailPreferences    String    @default("{}")
  stripeCustomerId    String?   @unique
  pushSubscription    String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  achievements            UserAchievement[]
  mangaList             UserManga[]
  library               UserLibrary[]
  readingProgress       ReadingProgress[]
  createdMangas         MangaSeries[] @relation("CreatedMangas")
  corrections           ChapterCorrection[]
  readingSessions       ReadingSession[]
  transactions          Transaction[]
  sponsorshipBids       SponsorshipBid[]
  notifications         Notification[]
  tipsGiven             Tip[] @relation("TipsGiven")
  tipsReceived          Tip[] @relation("TipsReceived")
  crowdfundingContributions CrowdfundingContribution[]
  clanMemberships       ClanMembership[]
  comments              Comment[]
  commentLikes          CommentLike[]
  mentions              CommentMention[] @relation("Mentions")
  activities            UserActivity[]
  ledClan               Clan? @relation("ClanLeader")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([xpPoints])
}

model MangaSeries {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String?
  coverUrl      String?
  authorId      String
  authorName    String
  status        String   @default("ONGOING")
  tags          String
  totalViews    Int      @default(0)
  rating        Float?
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author        User     @relation("CreatedMangas", fields: [authorId], references: [id], onDelete: Cascade)
  chapters      Chapter[]
  libraryEntries UserLibrary[]
  userMangas    UserManga[]

  @@index([slug])
  @@index([authorId])
  @@index([status])
  @@index([rating])
}

model Chapter {
  id                  String   @id @default(uuid())
  mangaId             String
  chapterNumber       Int
  title               String?
  totalPages          Int      @default(0)
  pageUrls            String   @db.Text
  crowdfundingGoal    Int?
  crowdfundingCurrent Int      @default(0)
  isCrowdfunded       Boolean  @default(false)
  viewCount           Int      @default(0)
  createdAt           DateTime @default(now())

  manga               MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  comments            Comment[]
  readingProgress     ReadingProgress[]
  tips                Tip[]
  crowdfundingContributions CrowdfundingContribution[]

  @@unique([mangaId, chapterNumber])
  @@index([mangaId])
  @@index([createdAt])
}

model UserLibrary {
  id              String   @id @default(uuid())
  userId          String
  mangaId         String
  status          String   @default("READING")
  currentChapter  Int      @default(0)
  rating          Float?
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga           MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
  @@index([mangaId])
}

model ReadingProgress {
  id            String   @id @default(uuid())
  userId        String
  mangaId       String
  chapterId     String
  currentPage   Int      @default(0)
  completed     Boolean  @default(false)
  completedAt   DateTime?
  lastReadAt    DateTime @default(now())
  durationSeconds Int    @default(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([completed])
}

model Comment {
  id            String   @id @default(uuid())
  chapterId     String
  userId        String
  content       String
  parentId      String?
  likesCount    Int      @default(0)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())

  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies       Comment[] @relation("CommentReplies")
  likes         CommentLike[]
  mentions      CommentMention[]

  @@index([chapterId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model CommentLike {
  id            String   @id @default(uuid())
  commentId     String
  userId        String
  createdAt     DateTime @default(now())

  comment       Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommentMention {
  id            String   @id @default(uuid())
  commentId     String
  mentionedUserId String
  createdAt     DateTime @default(now())

  comment       Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User     @relation("Mentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([commentId])
  @@index([mentionedUserId])
}

model AchievementDefinition {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String
  xpReward      Int
  iconUrl       String?
  condition     String
  category      String
  badgeId       String
  createdAt     DateTime @default(now())

  achievements  UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  type          String
  title         String
  message       String
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  type          String
  amount        Int
  description   String?
  metadata      String?  @db.Text
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Tip {
  id            String   @id @default(uuid())
  chapterId     String
  fromUserId    String
  toUserId      String
  amount        Int
  message       String?
  createdAt     DateTime @default(now())

  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  fromUser      User     @relation("TipsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser        User     @relation("TipsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
}

model CrowdfundingContribution {
  id            String   @id @default(uuid())
  chapterId     String
  userId        String
  amount        Int
  createdAt     DateTime @default(now())

  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chapterId, userId])
  @@index([chapterId])
  @@index([userId])
}

model SponsorshipBid {
  id            String   @id @default(uuid())
  chapterId     String
  userId        String
  amount        Int
  message       String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([userId])
  @@index([expiresAt])
}

model UserManga {
  id            String   @id @default(uuid())
  userId        String
  mangaId       String
  isFollowing   Boolean  @default(true)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga         MangaSeries @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
  @@index([mangaId])
}

model ChapterCorrection {
  id            String   @id @default(uuid())
  chapterId     String
  userId        String
  correctionType String
  description   String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([userId])
  @@index([status])
}

model ReadingSession {
  id            String   @id @default(uuid())
  userId        String
  mangaId       String?
  chapterId     String?
  startTime     DateTime @default(now())
  endTime       DateTime?
  durationSeconds Int  @default(0)
  pagesRead     Int    @default(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
}

model UserActivity {
  id            String   @id @default(uuid())
  userId        String
  activityType  String
  metadata      String?  @db.Text
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
}

model Clan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  emblemUrl     String?
  leaderId      String?  @unique
  totalScore    Int      @default(0)
  monthlyScore  Int      @default(0)
  currentSeason Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leader        User?    @relation("ClanLeader", fields: [leaderId], references: [id])
  members       ClanMembership[]

  @@index([totalScore])
  @@index([monthlyScore])
  @@index([currentSeason])
}

model ClanMembership {
  id            String   @id @default(uuid())
  clanId        String
  userId        String
  role          String   @default("MEMBER")
  joinedAt      DateTime @default(now())

  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
}
